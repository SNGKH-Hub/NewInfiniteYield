        Size = UDim2.new(1, 0, 0, 10),
        Position = UDim2.new(0, 0, 1, -10),
        BackgroundColor3 = Theme.Surface,
        BorderSizePixel = 0,
        ZIndex = 2,
        Parent = titlebar,
    })

    -- Accent bar
    CreateInstance("Frame", {
        Name = "AccentBar",
        Size = UDim2.new(0, 3, 0, 28),
        Position = UDim2.new(0, 16, 0.5, -14),
        BackgroundColor3 = Theme.Accent,
