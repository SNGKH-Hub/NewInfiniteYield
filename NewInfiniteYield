-- ─────────────────────────────────────────
-- UTILITY
-- ─────────────────────────────────────────
local function Tween(obj, props, duration, style, direction)
    local info = TweenInfo.new(
        duration or 0.18,
        style or Enum.EasingStyle.Quart,
        direction or Enum.EasingDirection.Out
    )
    TweenService:Create(obj, info, props):Play()
end

local function MakeDraggable(frame, handle)
    handle = handle or frame
    local dragging, dragInput, dragStart, startPos

    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
        end
    end)

    handle.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            dragInput = input
        end
    end)

    RunService.Heartbeat:Connect(function()
        if dragging and dragInput then
            local delta = dragInput.Position - dragStart
            frame.Position = UDim2.new(
                startPos.X.Scale,
                startPos.X.Offset + delta.X,
                startPos.Y.Scale,
                startPos.Y.Offset + delta.Y
            )
        end
    end)
end

local function CreateInstance(class, props, children)
    local inst = Instance.new(class)
    for k, v in pairs(props or {}) do
        inst[k] = v
    end
    for _, child in ipairs(children or {}) do
        child.Parent = inst
    end
    return inst
end

local function RoundedFrame(props)
    local frame = CreateInstance("Frame", props)
    CreateInstance("UICorner", { CornerRadius = UDim.new(0, 8) }, {}).Parent = frame
    return frame
end

local function StrokeFrame(frame, thickness, color)
    local stroke = Instance.new("UIStroke")
    stroke.Thickness = thickness or 1
    stroke.Color = color or Theme.Border
    stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    stroke.Parent = frame
    return stroke
end

-- ─────────────────────────────────────────
-- TOGGLE WINDOW BUTTON
-- ─────────────────────────────────────────
local function CreateToggleButton(window, mainFrame)
    local btn = RoundedFrame({
        Name = "ToggleButton",
        Size = UDim2.new(0, 120, 0, 36),
        Position = UDim2.new(0, 20, 1, -56),
        BackgroundColor3 = Theme.Surface,
        Active = true,
        Parent = PlayerGui:FindFirstChild("NexusUI") or PlayerGui,
    })
    btn.UICorner.CornerRadius = UDim.new(0, 18)
    StrokeFrame(btn, 1, Theme.Border)

    local dot = CreateInstance("Frame", {
        Size = UDim2.new(0, 8, 0, 8),
        Position = UDim2.new(0, 14, 0.5, -4),
        BackgroundColor3 = Theme.Accent,
        Parent = btn,
    })
    CreateInstance("UICorner", { CornerRadius = UDim.new(1, 0) }).Parent = dot

    CreateInstance("TextLabel", {
        Size = UDim2.new(1, -32, 1, 0),
        Position = UDim2.new(0, 30, 0, 0),
        BackgroundTransparency = 1,
        Text = "Toggle UI",
        TextColor3 = Theme.TextPrimary,
        TextSize = 13,
        Font = Enum.Font.GothamMedium,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = btn,
    })

    local visible = true
    local clickArea = CreateInstance("TextButton", {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        Text = "",
        Parent = btn,
    })

    clickArea.MouseButton1Click:Connect(function()
        visible = not visible
        if visible then
            mainFrame.Visible = true
            Tween(mainFrame, { GroupTransparency = 0 }, 0.2)
            Tween(dot, { BackgroundColor3 = Theme.Accent }, 0.2)
        else
            Tween(mainFrame, { GroupTransparency = 1 }, 0.15)
            task.delay(0.15, function() mainFrame.Visible = false end)
            Tween(dot, { BackgroundColor3 = Theme.TextMuted }, 0.2)
        end
    end)

    clickArea.MouseEnter:Connect(function()
        Tween(btn, { BackgroundColor3 = Theme.SurfaceLight }, 0.15)
    end)
    clickArea.MouseLeave:Connect(function()
        Tween(btn, { BackgroundColor3 = Theme.Surface }, 0.15)
    end)

    return btn
end

